# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key-here

# Optional: Supabase Service Role (server-side only, never expose to client)
# Clé service (Dashboard → Project Settings → API) — scripts/create-leadfarm-user.mjs uniquement, ne pas commiter
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Use mock parcelles when regions table is not migrated on Supabase yet
# NEXT_PUBLIC_MOCK_PARCELLES=true

# Optionnel : email pré-rempli sur /login en local
# NEXT_PUBLIC_DEMO_EMAIL=akram@leadfarm.dz

# NEXT_PUBLIC_ALLOW_DEMO_ROLE=true  # DEV ONLY — never enable in production

# Production agronome: assign role in Supabase user_profiles (role = agronome)
# Apply migration 033_agronome_role_satellite.sql before inserting agronome users

# Sans Supabase : rôle par défaut (directeur | magasinier | agronome | operateur | …)
# NEXT_PUBLIC_DEMO_ROLE=agronome

# Copernicus CDSE — Sentinel Hub Statistical API (production, obligatoire pour /satellite)
# Créer une OAuth client sur https://dataspace.copernicus.eu/
SENTINEL_HUB_CLIENT_ID=your-cdse-client-id
SENTINEL_HUB_CLIENT_SECRET=your-cdse-client-secret

# OpenWeatherMap — couches vent/pluie live sur la carte dashboard (serveur uniquement)
# OPENWEATHERMAP_API_KEY=your-openweathermap-api-key

# IoT device auth (ESP32 → POST /api/readings, camera upload)
DEVICE_API_KEY=your-device-api-key

# Internal service token (alert webhooks, camera fallback)
SERVICE_TOKEN=your-service-token

# Public app URL for QR trace certificate links
NEXT_PUBLIC_APP_URL=https://your-app.vercel.app

# Assistant IA (Léa) — clé Anthropic, serveur uniquement (ne jamais exposer au client)
# Assistant IA (Léa) — requis en production sur leadfarm-app
ANTHROPIC_API_KEY=your-anthropic-api-key
# Modèle optionnel (défaut: claude-sonnet-4-6)
# ANTHROPIC_MODEL=claude-sonnet-4-6
# Modèle ONNX maladies pommier (défaut: models/apple-disease.onnx dans la racine du projet)
# APPLE_DISEASE_MODEL_PATH=/chemin/absolu/vers/best.onnx
# Taille d'entrée du modèle en pixels (défaut: 640 pour YOLOv8 imgsz=640)
# APPLE_DISEASE_INPUT_SIZE=640

# ── whapi.cloud WhatsApp AI agent ──
# Secret you choose; must match the ?token= in the webhook URL set in whapi.cloud.
WHAPI_WEBHOOK_TOKEN=
# API token for sending replies (whapi Dashboard → Channels → your channel → Token).
WHAPI_TOKEN=
# Optional: restrict ingestion/replies to a single group chat_id (ends with @g.us).
WHAPI_GROUP_ID=
# Optional: Supabase service role key for full data access in the agent (bypasses RLS).
# SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
