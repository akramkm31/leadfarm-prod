# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies (any depth: root, server/, etc.)
node_modules/
.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
coverage/

# next.js
.next/
out/

# production / compiled
build/
dist/
.turbo/

# misc
.DS_Store
Thumbs.db
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (never commit secrets)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# IDE / local agent settings
.claude/
.cursor/
.idea/
.vscode/*
!.vscode/extensions.json
!.vscode/settings.json.example

# local dev scratch (DB probes, one-off scripts)
scratch/

# prisma local db (if used)
*.db
*.db-journal
